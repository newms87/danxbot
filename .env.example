# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_CHANNEL_ID=C0123456789

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Repos (cloned into shared Docker volume, format: name:url,name:url)
REPOS=platform:https://github.com/Flytedesk/platform.git

# Database (read-only production access)
PLATFORM_DB_HOST=your-rds-host.amazonaws.com
PLATFORM_DB_USER=flytebot_readonly
PLATFORM_DB_PASSWORD=your-secure-password
PLATFORM_DB_NAME=platform

# Trello (for poller)
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_TOKEN=your-trello-api-token

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-5
# MAX_TURNS=30
# MAX_BUDGET_USD=1.00
# LOG_LEVEL=info
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
