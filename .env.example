# Runtime: "docker" (default) or "host"
# docker: API key auth, piped agent output, DB via container hostname, logs to /danxbot/logs
# host: subscription auth (Claude Max), interactive terminal tabs, DB via localhost:3307, logs to ./logs
DANXBOT_RUNTIME=docker

# Anthropic (required in docker mode, optional in host mode — host uses Claude subscription)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Repos (cloned into shared Docker volume, format: name:url,name:url)
REPOS=example-repo:https://github.com/example-org/example-repo.git

# Slack (optional — bot works without Slack for Trello card processing)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# Connected Repo Database (optional — for SQL query capability)
PLATFORM_DB_HOST=
PLATFORM_DB_USER=
PLATFORM_DB_PASSWORD=
PLATFORM_DB_NAME=

# Trello (secrets only — board/list/label IDs live in .danxbot/config/trello.yml in the connected repo)
TRELLO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TRELLO_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TRELLO_REVIEW_MIN_CARDS=10

# Docker network (must match the connected repo's Docker network for cross-container communication)
DOCKER_NETWORK=example-repo_sail

# Dashboard port (each instance needs a unique port to avoid conflicts)
DASHBOARD_PORT=5555

# Git identity for commits made by danxbot
DANXBOT_GIT_EMAIL=danxbot@example-org.com

# Danxbot Database (defaults: docker=mysql:3306, host=127.0.0.1:3307 — override if needed)
DANXBOT_DB_USER=danxbot
DANXBOT_DB_PASSWORD=danxbot
DANXBOT_DB_NAME=danxbot_chat

# Poller
POLLER_INTERVAL_MS=60000

# Remote Agent Dispatch — launches schema builder agents via @thehammer/schema-mcp-server npm package
# DEFAULT_API_URL=http://laravel.test:80
# DISPATCH_AGENT_TIMEOUT=600

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-5
# MAX_TURNS=30
# MAX_BUDGET_USD=1.00
# LOG_LEVEL=info
# GITHUB_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
