# === Shared Infrastructure ===
# Per-repo secrets (Slack, Trello, GitHub, DB) live in <repo>/.danxbot/.env

# Runtime is auto-detected from /.dockerenv — no config needed.
# Inside a container → docker mode: headless agents, DB at mysql:3306, logs to /danxbot/logs.
# On the host → host mode: interactive Windows Terminal tabs, DB at 127.0.0.1:<DANXBOT_DB_PORT>, logs to ./logs.
# Both modes have identical monitoring behavior.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-api-key
CLAUDE_AUTH_MODE=subscription

# === Claude Code credentials (REQUIRED for the danxbot worker) ===
# `make launch-worker REPO=danxbot` and `docker compose -f .danxbot/config/compose.yml`
# both refuse to start when these are unset. Point each at your live host
# Claude Code auth file/dir so token rotation on the host is visible inside
# the worker container without a restart. Leaving them unset previously fell
# back to a stale snapshot dir that broke dispatches within ~24h of setup
# (Trello th8GCprR). Full rationale (file-bind vs dir-bind, why RW, UID
# alignment) lives next to the mounts in `.danxbot/config/compose.yml`.
# Prod deploy injects absolute provisioned paths automatically.
#
# Copy this block, replace `you` with your Linux username, and uncomment:
#
# CLAUDE_CONFIG_FILE=/home/you/.claude.json
# CLAUDE_CREDS_DIR=/home/you/.claude

# Connected repos + per-repo worker ports come from
# deploy/targets/<DANXBOT_TARGET>.yml (default target: `local`).
# Edit deploy/targets/local.yml to add/remove connected repos for this
# dev environment. Pre-Phase-B these lived in REPOS / REPO_WORKER_PORTS
# CSV env vars that routinely desynced — now there's one YML.

# Danxbot Database (credentials only — host/port derived from runtime detection)
DANXBOT_DB_USER=danxbot
DANXBOT_DB_PASSWORD=danxbot
DANXBOT_DB_NAME=danxbot_chat
DANXBOT_DB_PORT=3308

# Dashboard + Poller
# Per-repo Trello polling is controlled by DANX_TRELLO_ENABLED in <repo>/.danxbot/.env.
DASHBOARD_PORT=5555
# Host port for the Vite HMR dashboard-dev container. 5566 is the
# permanent danxbot dev port — picked to avoid collisions with Vite's
# default 5173 (other projects). Do not change unless 5566 itself is taken.
DASHBOARD_DEV_PORT=5566
POLLER_INTERVAL_MS=60000
TRELLO_REVIEW_MIN_CARDS=10

# Git
DANXBOT_GIT_EMAIL=danxbot@example-org.com

# Dashboard root user — provisioned / refreshed by `make ensure-root-user`
# (also run automatically at the end of `make deploy TARGET=<t>`). Format:
# "username//password". Idempotent: no DB write and no token rotation when
# the password already matches.
#
# Single-quote the value if the password contains shell metachars (`$`, `!`,
# backticks) so install.sh's `set -a; . ./.env` doesn't expand them.
# DANX_DASHBOARD_ROOT_USER='admin//change-me-12-chars-min'

# MCP server secrets (used by .mcp.json env var expansion)
TRELLO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TRELLO_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MCP_TRELLO_PATH=/path/to/mcp-server-trello

# Remote Agent Dispatch
# DEFAULT_API_URL=http://localhost:80
# DISPATCH_AGENT_TIMEOUT=600

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-5
# MAX_TURNS=30
# MAX_BUDGET_USD=1.00
# LOG_LEVEL=info
# GITHUB_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
