# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-api-key

# GitHub
GITHUB_TOKEN=ghp_your-github-token

# Repos (cloned into shared Docker volume, format: name:url,name:url)
REPOS=myrepo:https://github.com/org/repo.git

# Slack (optional — bot works without Slack for Trello card processing)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# Connected Repo Database (optional — for SQL query capability)
PLATFORM_DB_HOST=
PLATFORM_DB_USER=
PLATFORM_DB_PASSWORD=
PLATFORM_DB_NAME=

# Trello
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_TOKEN=your-trello-api-token
TRELLO_BOARD_ID=your-board-id
TRELLO_REVIEW_LIST_ID=your-review-list-id
TRELLO_TODO_LIST_ID=your-todo-list-id
TRELLO_IN_PROGRESS_LIST_ID=your-in-progress-list-id
TRELLO_NEEDS_HELP_LIST_ID=your-needs-help-list-id
TRELLO_DONE_LIST_ID=your-done-list-id
TRELLO_CANCELLED_LIST_ID=your-cancelled-list-id
TRELLO_ACTION_ITEMS_LIST_ID=your-action-items-list-id
TRELLO_BUG_LABEL_ID=your-bug-label-id
TRELLO_FEATURE_LABEL_ID=your-feature-label-id
TRELLO_EPIC_LABEL_ID=your-epic-label-id
TRELLO_NEEDS_HELP_LABEL_ID=your-needs-help-label-id
TRELLO_REVIEW_MIN_CARDS=10

# Flytebot Database
FLYTEBOT_DB_HOST=flytebot-mysql
FLYTEBOT_DB_USER=flytebot
FLYTEBOT_DB_PASSWORD=flytebot
FLYTEBOT_DB_NAME=flytebot_chat

# Poller
POLLER_INTERVAL_MS=60000

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-5
# MAX_TURNS=30
# MAX_BUDGET_USD=1.00
# LOG_LEVEL=info
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
