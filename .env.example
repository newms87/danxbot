# Runtime: "docker" (default) or "host"
# docker: piped agent output, DB via container hostname, logs to /danxbot/logs
# host: interactive terminal tabs, DB via localhost:3307, logs to ./logs
DANXBOT_RUNTIME=docker

# Claude auth for spawned agents: "api-key" or "subscription" (Claude Max/Pro)
# api-key: uses ANTHROPIC_API_KEY (required)
# subscription: uses ~/.claude/.credentials.json (must exist)
CLAUDE_AUTH_MODE=api-key

# Anthropic (required when CLAUDE_AUTH_MODE=api-key)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Repos (symlinked in repos/, format: name:url,name:url)
REPOS=example-repo:https://github.com/example-org/example-repo.git

# Compose files — include repo-specific overrides that mount symlink targets into Docker
# COMPOSE_FILE=docker-compose.yml:repo-overrides/example-repo-compose.yml

# Slack (optional — bot works without Slack for Trello card processing)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# Connected Repo Database (optional — for SQL query capability)
PLATFORM_DB_HOST=
PLATFORM_DB_USER=
PLATFORM_DB_PASSWORD=
PLATFORM_DB_NAME=

# Trello (secrets only — board/list/label IDs live in .danxbot/config/trello.yml in the connected repo)
TRELLO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TRELLO_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TRELLO_REVIEW_MIN_CARDS=10

# Per-repo host paths (so symlinks in repos/ resolve inside Docker containers)
# Each connected repo's .danxbot/config/compose.yml references its own var.
# PLATFORM_REPO_HOST_DIR=/home/user/web/platform

# Docker network (must match the connected repo's Docker network for cross-container communication)
DOCKER_NETWORK=example-repo_sail

# Dashboard port (each instance needs a unique port to avoid conflicts)
DASHBOARD_PORT=5555

# Git identity for commits made by danxbot
DANXBOT_GIT_EMAIL=danxbot@example-org.com

# Danxbot Database
DANXBOT_DB_HOST=mysql
DANXBOT_DB_USER=danxbot
DANXBOT_DB_PASSWORD=danxbot
DANXBOT_DB_NAME=danxbot_chat
# DANXBOT_DB_INTERNAL_PORT=3306   # Port inside the container (default: 3306)
# DANXBOT_DB_PORT=3307             # Port exposed to the host (default: 3307)

# Poller
POLLER_INTERVAL_MS=60000

# Remote Agent Dispatch — launches schema builder agents via @thehammer/schema-mcp-server npm package
# DEFAULT_API_URL=http://laravel.test:80
# DISPATCH_AGENT_TIMEOUT=600

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-5
# MAX_TURNS=30
# MAX_BUDGET_USD=1.00
# LOG_LEVEL=info
# GITHUB_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
