node_modules/
# Match `node_modules` as a bare name too — git's `node_modules/` (with
# trailing slash) only matches directories, NOT symlinks pointing at a
# node_modules dir. Worktree-test workflows symlink node_modules into
# the worktree (the symlink is created by the operator / CI to share
# the parent checkout's deps); without this bare entry the symlink
# becomes an untracked entry that `git add -A` happily commits as a
# 120000-mode entry pointing at the operator's host filesystem.
node_modules
dist/
docker-compose.override.yml
.env
.env.local
# Per-target overlays consumed by deploy/secrets.ts (e.g. .env.platform,
# .env.gpt) — same secret content as .env, so always gitignored.
# Allow .env.example so the convention can be committed.
.env.*
!.env.example
threads/
data/
.poller-running
dashboard/dist/
dashboard/node_modules/
dashboard/node_modules
*.tsbuildinfo

.claude/settings.local.json
.claude/clad.json
.claude/agent-self-improvement.md
.claude/projects/
.claude/scheduled_tasks.lock
agent-notes.md
claude-auth/*
!claude-auth/.gitkeep
.claude/rules/trello-config.md

# Repo-specific files (source of truth: .danxbot/config/ in connected repo, synced by poller)
.claude/rules/repo-config.md
.claude/rules/repo-overview.md
.claude/rules/repo-workflow.md
.claude/rules/danx-repo-config.md
.claude/rules/danx-repo-overview.md
.claude/rules/danx-repo-workflow.md
.claude/rules/danx-trello-config.md
.claude/skills/danx-*
repo-overrides/*
!repo-overrides/.gitkeep
docs/domains/
docs/schema/
docs/features.md
repos/

# Runtime artifacts from dispatch + poller
logs/
# Claude Code session logs for this repo's worker (bind-mounted to /home/danxbot/.claude/projects)
claude-projects/
# Tools injected by the danxbot poller
.claude/tools/

# Ephemeral scratch from superpowers:brainstorming sessions
.superpowers/

# Terraform local state + generated tfvars
deploy/terraform/.terraform/
deploy/terraform/terraform.tfvars.json

# Real deploy configs (contain deployment-specific identifiers)
deploy/targets/*.yml
!deploy/targets/example.yml

# Per-target Terraform output cache (publicIp etc.) — written by `deploy`,
# read by read-only commands (create-user) to skip the ~10s Terraform
# pre-flight. See deploy/output-cache.ts for the contract.
deploy/targets/.cache/

# Generated by the inject pipeline when this repo is connected to itself.
# Source of truth: src/poller/inject/workspaces/<name>/ (committed).
.danxbot/workspaces/
.danxbot/CRITICAL_FAILURE
# DX-324 — per-minute system cron tick state (lastRunMs per registered job)
.danxbot/cron-state.json
