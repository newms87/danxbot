{
  "name": "danxbot",
  "version": "1.0.0",
  "description": "Autonomous AI agent powered by Claude Code SDK",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:validate": "vitest run --config vitest.validation.config.ts",
    "poller": "tsx --env-file=.env src/poller/index.ts",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@slack/bolt": "^4.1.0",
    "@thehammer/schema-mcp-server": "^1.0.3",
    "bcrypt": "^6.0.0",
    "mysql2": "^3.17.1",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
