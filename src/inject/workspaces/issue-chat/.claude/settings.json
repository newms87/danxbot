{
  "env": {
    "DANX_AGENT_WORKTREE": "${DANX_AGENT_WORKTREE}"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/worktree-guard.mjs"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "newms-plugins": {
      "source": {
        "source": "github",
        "repo": "newms87/claude-plugins"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "base@newms-plugins": true,
    "danxbot@newms-plugins": true
  }
}
