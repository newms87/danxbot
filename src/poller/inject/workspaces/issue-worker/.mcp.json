{
  "mcpServers": {
    "danx-issue": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@thehammer/danx-issue-mcp"],
      "env": {
        "DANX_REPO_ROOT": "${DANX_REPO_ROOT}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["tsx", "mcp-servers/playwright/src/index.ts"],
      "env": {
        "PLAYWRIGHT_URL": "http://playwright:3000"
      }
    }
  }
}
