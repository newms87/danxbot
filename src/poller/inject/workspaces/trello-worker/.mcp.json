{
  "mcpServers": {
    "trello": {
      "command": "npx",
      "args": ["-y", "@thehammer/mcp-server-trello"],
      "env": {
        "TRELLO_API_KEY": "${TRELLO_API_KEY}",
        "TRELLO_TOKEN": "${TRELLO_TOKEN}",
        "TRELLO_BOARD_ID": "${TRELLO_BOARD_ID}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["tsx", "mcp-servers/playwright/src/index.ts"],
      "env": {
        "PLAYWRIGHT_URL": "http://playwright:3000"
      }
    }
  }
}
